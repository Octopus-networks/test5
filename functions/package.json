{
  "name": "mithaq-functions",
  "description": "Privileged backend functions for Mithaq",
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "scripts": {
    "lint": "node --check index.js && node --check publicProfileMirror.js && node --check scripts/backfillPublicProfiles.js && node --check scripts/testPublicProfileMirror.js",
    "test": "node scripts/testPublicProfileMirror.js",
    "backfill:publicProfiles": "node scripts/backfillPublicProfiles.js",
    "serve": "firebase emulators:start --only functions,firestore,auth,storage",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.1"
  },
  "private": true
}
