rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function canReadProfileMedia(imageId) {
      return isAdmin() ||
        imageId.matches(request.auth.uid + '(_additional_[0-9]+)?\\.jpg');
    }

    function canReadVoiceIntro(voiceId) {
      return isAdmin() || voiceId == request.auth.uid + '.mp4';
    }

    function validVerificationDocument(documentId) {
      return documentId in ['id_card.jpg', 'selfie.jpg', 'selfie_video.mp4'];
    }

    function approvedPhotoRequest(ownerId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/photoRequests/$(request.auth.uid + '_' + ownerId)) &&
        firestore.get(/databases/(default)/documents/photoRequests/$(request.auth.uid + '_' + ownerId)).data.status == 'approved';
    }

    match /profiles/{imageId} {
      // Sensitive profile media is not public-by-authentication anymore.
      // The owner/admin can read legacy paths; approved-viewer access should move
      // to a dedicated private media flow before production.
      allow read: if isAuthenticated() && canReadProfileMedia(imageId);
      allow create, update: if isAuthenticated() &&
        imageId.matches(request.auth.uid + '(_additional_[0-9]+)?\\.jpg') &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    match /voices/{voiceId} {
      // Voice introductions may reveal identity; keep them owner/admin-only until
      // an explicit approved-list access model is implemented.
      allow read: if isAuthenticated() && canReadVoiceIntro(voiceId);
      allow create, update: if isAuthenticated() &&
        voiceId == request.auth.uid + '.mp4' &&
        request.resource.size < 15 * 1024 * 1024 &&
        request.resource.contentType.matches('audio/.*|video/.*');
      allow delete: if false;
    }

    match /verification/{userId}/{documentId} {
      allow read: if isAdmin();
      allow create: if isOwner(userId) &&
        validVerificationDocument(documentId) &&
        request.resource.size < 20 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
      // Do not allow clients to replace verification evidence after submission.
      allow update: if false;
      allow delete: if false;
    }

    // Phase 11: secure user photos. Owner writes their own; reads are limited to the
    // owner, an admin, or a viewer holding an approved photo request for this owner.
    // Private photo bytes are never public and never served via a stored URL.
    // A photo the owner set to "hidden" must not be downloadable even by viewers who
    // hold an approved photo request. Metadata doc id is the object name minus ".jpg".
    function photoNotHidden(userId, photoId) {
      return firestore.get(/databases/(default)/documents/userPhotos/$(userId)/photos/$(photoId.split('\\.')[0])).data.visibility != 'hidden';
    }

    match /user_photos/{userId}/{photoId} {
      allow read: if isOwner(userId) || isAdmin() ||
        (approvedPhotoRequest(userId) && photoNotHidden(userId, photoId));
      allow create, update: if isOwner(userId) &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // Chat attachments (images + voice notes). Readable/writable only by the chat's
    // participants (or an admin, for report moderation). One object per message, stored at
    // chat_attachments/{chatId}/{messageId}. Bytes are never public and never served via a
    // stored URL — clients fetch them through the authenticated Storage SDK.
    match /chat_attachments/{chatId}/{attachmentId} {
      function isChatMember() {
        return isAuthenticated() &&
          request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participantIds;
      }
      allow read: if isChatMember() || isAdmin();
      allow create: if isChatMember() &&
        request.resource.size < 10 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('audio/.*')
        );
      allow update, delete: if false;
    }
  }
}
