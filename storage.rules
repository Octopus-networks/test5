rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function canReadProfileMedia(imageId) {
      return isAdmin() ||
        imageId.matches(request.auth.uid + '(_additional_[0-9]+)?\\.jpg');
    }

    function canReadVoiceIntro(voiceId) {
      return isAdmin() || voiceId == request.auth.uid + '.mp4';
    }

    function validVerificationDocument(documentId) {
      return documentId in ['id_card.jpg', 'selfie.jpg', 'selfie_video.mp4'];
    }

    function approvedPhotoRequestFor(ownerUserId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/photoRequests/$(request.auth.uid + '_' + ownerUserId)) &&
        firestore.get(/databases/(default)/documents/photoRequests/$(request.auth.uid + '_' + ownerUserId)).data.status == 'approved';
    }

    match /user_photos/{userId}/{photoFile} {
      allow read: if isOwner(userId) || isAdmin() || approvedPhotoRequestFor(userId);
      allow create: if isOwner(userId) &&
        photoFile.matches('[A-Za-z0-9_-]+\\.jpg') &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.metadata.userId == userId;
      allow update, delete: if false;
    }

    match /profiles/{imageId} {
      // Sensitive profile media is not public-by-authentication anymore.
      // The owner/admin can read legacy paths; approved-viewer access should move
      // to a dedicated private media flow before production.
      allow read: if isAuthenticated() && canReadProfileMedia(imageId);
      allow create, update: if isAuthenticated() &&
        imageId.matches(request.auth.uid + '(_additional_[0-9]+)?\\.jpg') &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    match /voices/{voiceId} {
      // Voice introductions may reveal identity; keep them owner/admin-only until
      // an explicit approved-list access model is implemented.
      allow read: if isAuthenticated() && canReadVoiceIntro(voiceId);
      allow create, update: if isAuthenticated() &&
        voiceId == request.auth.uid + '.mp4' &&
        request.resource.size < 15 * 1024 * 1024 &&
        request.resource.contentType.matches('audio/.*|video/.*');
      allow delete: if false;
    }

    match /verification/{userId}/{documentId} {
      allow read: if isAdmin();
      allow create: if isOwner(userId) &&
        validVerificationDocument(documentId) &&
        request.resource.size < 20 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
      // Do not allow clients to replace verification evidence after submission.
      allow update: if false;
      allow delete: if false;
    }
  }
}
