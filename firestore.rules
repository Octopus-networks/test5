rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isVerifiedEmailUser() {
      return isAuthenticated() &&
        request.auth.token.email_verified == true;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "isAdmin",
        "isPremium",
        "subscriptionPlan",
        "premiumExpiry",
        "verificationStatus",
        "guardianName",
        "guardianEmail",
        "guardianStatus",
        "photoAccessApprovedUsers",
        "photoAccessRequests",
        "isWaliAccount",
        "wardUid"
      ]);
    }

    function validInitialGuardianState() {
      return !("guardianStatus" in request.resource.data) ||
        request.resource.data.guardianStatus == "NONE" ||
        (
          request.resource.data.guardianStatus == "PENDING" &&
          request.resource.data.guardianName is string &&
          request.resource.data.guardianName.size() > 0 &&
          request.resource.data.guardianEmail is string &&
          request.resource.data.guardianEmail.size() > 3
        );
    }

    function validGuardianInvite() {
      return changedOnly(["guardianName", "guardianEmail", "guardianStatus"]) &&
        request.resource.data.guardianName is string &&
        request.resource.data.guardianName.size() > 0 &&
        request.resource.data.guardianEmail is string &&
        request.resource.data.guardianEmail.size() > 3 &&
        request.resource.data.guardianStatus == "PENDING";
    }

    function validWaliClaim() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        changedOnly(["isWaliAccount", "wardUid"]) &&
        request.resource.data.isWaliAccount == true &&
        request.resource.data.wardUid is string &&
        exists(/databases/$(database)/documents/users/$(request.resource.data.wardUid)) &&
        get(/databases/$(database)/documents/users/$(request.resource.data.wardUid)).data.guardianEmail == request.auth.token.email;
    }

    function validGuardianConfirmation() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        changedOnly(["guardianStatus"]) &&
        request.resource.data.guardianStatus == "VERIFIED" &&
        resource.data.guardianEmail == request.auth.token.email;
    }

    function validVerificationSubmission() {
      return isAuthenticated() &&
        changedOnly(["verificationStatus"]) &&
        request.resource.data.verificationStatus == "PENDING" &&
        resource.data.verificationStatus != "VERIFIED";
    }

    function existingPhotoRequests() {
      return ("photoAccessRequests" in resource.data)
        ? resource.data.photoAccessRequests
        : [];
    }

    function existingPhotoApprovedUsers() {
      return ("photoAccessApprovedUsers" in resource.data)
        ? resource.data.photoAccessApprovedUsers
        : [];
    }

    function validPhotoAccessRequest(userId) {
      return isAuthenticated() &&
        request.auth.uid != userId &&
        changedOnly(["photoAccessRequests"]) &&
        request.resource.data.photoAccessRequests is list &&
        request.resource.data.photoAccessRequests.hasAll(existingPhotoRequests()) &&
        request.auth.uid in request.resource.data.photoAccessRequests &&
        request.resource.data.photoAccessRequests.size() <= existingPhotoRequests().size() + 1;
    }

    function isAssignedWaliForUser(userId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid == userId;
    }

    function validPhotoAccessDecision() {
      return changedOnly(["photoAccessApprovedUsers", "photoAccessRequests"]) &&
        request.resource.data.photoAccessApprovedUsers is list &&
        request.resource.data.photoAccessRequests is list &&
        request.resource.data.photoAccessRequests.size() <= existingPhotoRequests().size() &&
        request.resource.data.photoAccessApprovedUsers.size() <= existingPhotoApprovedUsers().size() + 1;
    }

    function hasMutualMatch(memberIds) {
      return memberIds is list &&
        memberIds.size() == 2 &&
        (memberIds[0] is string) &&
        (memberIds[1] is string) &&
        (
          (
            exists(/databases/$(database)/documents/likes/$(memberIds[0] + "_" + memberIds[1])) &&
            get(/databases/$(database)/documents/likes/$(memberIds[0] + "_" + memberIds[1])).data.isMutual == true
          ) ||
          (
            exists(/databases/$(database)/documents/likes/$(memberIds[1] + "_" + memberIds[0])) &&
            get(/databases/$(database)/documents/likes/$(memberIds[1] + "_" + memberIds[0])).data.isMutual == true
          )
        );
    }

    function roomExistsFor(uidA, uidB) {
      return exists(/databases/$(database)/documents/chatRooms/$(uidA + "_" + uidB)) ||
        exists(/databases/$(database)/documents/chatRooms/$(uidB + "_" + uidA)) ||
        exists(/databases/$(database)/documents/chats/$(uidA + "_" + uidB)) ||
        exists(/databases/$(database)/documents/chats/$(uidB + "_" + uidA));
    }

    function relatedForNotification(recipientUid) {
      return recipientUid is string &&
        recipientUid.size() > 0 &&
        (
          recipientUid == request.auth.uid ||
          exists(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + recipientUid)) ||
          exists(/databases/$(database)/documents/likes/$(recipientUid + "_" + request.auth.uid)) ||
          roomExistsFor(request.auth.uid, recipientUid)
        );
    }

    function hasAcceptedInterest(uidA, uidB) {
      return exists(/databases/$(database)/documents/interestRequests/$(uidA + "_" + uidB)) &&
        get(/databases/$(database)/documents/interestRequests/$(uidA + "_" + uidB)).data.status == "accepted" ||
        exists(/databases/$(database)/documents/interestRequests/$(uidB + "_" + uidA)) &&
        get(/databases/$(database)/documents/interestRequests/$(uidB + "_" + uidA)).data.status == "accepted";
    }

    function approvedChatRequestFor(uidA, uidB, requestId) {
      return requestId is string &&
        exists(/databases/$(database)/documents/chatRequests/$(requestId)) &&
        get(/databases/$(database)/documents/chatRequests/$(requestId)).data.status == "approved" &&
        (
          (
            get(/databases/$(database)/documents/chatRequests/$(requestId)).data.fromUserId == uidA &&
            get(/databases/$(database)/documents/chatRequests/$(requestId)).data.toUserId == uidB
          ) ||
          (
            get(/databases/$(database)/documents/chatRequests/$(requestId)).data.fromUserId == uidB &&
            get(/databases/$(database)/documents/chatRequests/$(requestId)).data.toUserId == uidA
          )
        );
    }

    function chatData(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function isChatParticipant(chatId) {
      return isVerifiedEmailUser() &&
        exists(/databases/$(database)/documents/chats/$(chatId)) &&
        request.auth.uid in chatData(chatId).participantIds;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAssignedWaliForUser(userId) || isAdmin();

      allow create: if isOwner(userId) &&
        request.resource.data.uid == request.auth.uid &&
        !("isAdmin" in request.resource.data) &&
        request.resource.data.get("isPremium", false) == false &&
        request.resource.data.get("subscriptionPlan", "FREE") == "FREE" &&
        request.resource.data.get("premiumExpiry", 0) == 0 &&
        request.resource.data.get("isWaliAccount", false) == false &&
        !("wardUid" in request.resource.data) &&
        request.resource.data.get("verificationStatus", "NONE") == "NONE" &&
        validInitialGuardianState();

      allow update: if
        (isOwner(userId) && noPrivilegeEscalation()) ||
        (isOwner(userId) && validGuardianInvite()) ||
        (isOwner(userId) && validWaliClaim()) ||
        (isOwner(userId) && validVerificationSubmission()) ||
        (isOwner(userId) && validPhotoAccessDecision()) ||
        (isAssignedWaliForUser(userId) && validPhotoAccessDecision()) ||
        validGuardianConfirmation() ||
        validPhotoAccessRequest(userId) ||
        isAdmin();

      allow delete: if false;

      match /chatLimits/{limitId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    match /profiles/{userId} {
      allow read: if (isVerifiedEmailUser() && request.auth.uid == userId) || isAdmin();
      allow create, update: if isVerifiedEmailUser() &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasOnly([
          "onboardingCompleted",
          "onboardingStep",
          "profileCompletionPercent",
          "basicInfo",
          "personalStatus",
          "religiousPractice",
          "marriageIntent",
          "publicSettings",
          "updatedAt"
        ]);
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if isVerifiedEmailUser() || isAdmin();
      allow create, update, delete: if false;
    }

    match /userPhotos/{userId}/photos/{photoId} {
      allow read: if isVerifiedEmailUser() && (request.auth.uid == userId || isAdmin());
      allow create: if isVerifiedEmailUser() &&
        request.auth.uid == userId &&
        request.resource.data.userId == userId &&
        request.resource.data.photoId == photoId &&
        request.resource.data.storagePath == "user_photos/" + userId + "/" + photoId + ".jpg" &&
        request.resource.data.type in ["main", "extra"] &&
        request.resource.data.status == "pending_review" &&
        request.resource.data.visibility in ["hidden", "blurred_by_default", "approved_users_only", "matched_users_only"] &&
        request.resource.data.keys().hasOnly([
          "photoId",
          "userId",
          "storagePath",
          "type",
          "status",
          "visibility",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isVerifiedEmailUser() &&
        request.auth.uid == userId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.photoId == resource.data.photoId &&
        request.resource.data.storagePath == resource.data.storagePath &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["visibility", "updatedAt"]);
      allow delete: if false;
    }

    match /interestRequests/{requestId} {
      allow read: if isVerifiedEmailUser() &&
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || isAdmin());
      allow create: if isVerifiedEmailUser() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId != request.auth.uid &&
        requestId == request.auth.uid + "_" + request.resource.data.toUserId &&
        request.resource.data.status == "pending" &&
        request.resource.data.keys().hasOnly([
          "requestId",
          "fromUserId",
          "toUserId",
          "fromDisplayName",
          "toDisplayName",
          "status",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isVerifiedEmailUser() && (
        (
          resource.data.fromUserId == request.auth.uid &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status in ["pending", "cancelled"] &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "fromDisplayName",
            "toDisplayName",
            "status",
            "createdAt",
            "updatedAt"
          ])
        ) ||
        (
          resource.data.toUserId == request.auth.uid &&
          resource.data.status == "pending" &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status in ["accepted", "declined"] &&
          changedOnly(["status", "updatedAt"])
        )
      );
      allow delete: if false;
    }

    match /photoRequests/{requestId} {
      allow read: if isVerifiedEmailUser() &&
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || isAdmin());
      allow create: if isVerifiedEmailUser() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId != request.auth.uid &&
        requestId == request.auth.uid + "_" + request.resource.data.toUserId &&
        request.resource.data.status == "pending" &&
        hasAcceptedInterest(request.auth.uid, request.resource.data.toUserId) &&
        request.resource.data.keys().hasOnly([
          "requestId",
          "fromUserId",
          "toUserId",
          "status",
          "relatedInterestRequestId",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isVerifiedEmailUser() && (
        (
          resource.data.fromUserId == request.auth.uid &&
          resource.data.status == "pending" &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status == "cancelled" &&
          changedOnly(["status", "updatedAt"])
        ) ||
        (
          resource.data.toUserId == request.auth.uid &&
          resource.data.status == "pending" &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status in ["approved", "declined"] &&
          changedOnly(["status", "updatedAt"])
        )
      );
      allow delete: if false;
    }

    match /chatRequests/{requestId} {
      allow read: if isVerifiedEmailUser() &&
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || isAdmin());
      allow create: if isVerifiedEmailUser() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId != request.auth.uid &&
        requestId == request.auth.uid + "_" + request.resource.data.toUserId &&
        request.resource.data.status == "pending" &&
        hasAcceptedInterest(request.auth.uid, request.resource.data.toUserId) &&
        request.resource.data.requiresGuardianApproval == false &&
        request.resource.data.guardianApprovalStatus == "not_required" &&
        request.resource.data.keys().hasOnly([
          "requestId",
          "fromUserId",
          "toUserId",
          "status",
          "relatedInterestRequestId",
          "requiresGuardianApproval",
          "guardianApprovalStatus",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isVerifiedEmailUser() && (
        (
          resource.data.fromUserId == request.auth.uid &&
          resource.data.status == "pending" &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status == "cancelled" &&
          changedOnly(["status", "updatedAt"])
        ) ||
        (
          resource.data.toUserId == request.auth.uid &&
          resource.data.status in ["pending", "approved"] &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.status in ["pending", "approved", "declined"] &&
          changedOnly(["status", "updatedAt"])
        ) ||
        (
          (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid) &&
          resource.data.status == "approved" &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.fromUserId == resource.data.fromUserId &&
          request.resource.data.toUserId == resource.data.toUserId &&
          request.resource.data.createdChatId is string &&
          changedOnly(["createdChatId", "updatedAt"])
        )
      );
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId) || isAdmin();
      allow create: if isVerifiedEmailUser() &&
        request.resource.data.chatId == chatId &&
        request.resource.data.participantIds is list &&
        request.resource.data.participantIds.size() == 2 &&
        request.resource.data.participantIds[0] is string &&
        request.resource.data.participantIds[1] is string &&
        request.resource.data.participantIds[0] != request.resource.data.participantIds[1] &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.status == "active" &&
        request.resource.data.guardianApprovalStatus == "not_required" &&
        approvedChatRequestFor(
          request.resource.data.participantIds[0],
          request.resource.data.participantIds[1],
          request.resource.data.createdFromChatRequestId
        ) &&
        request.resource.data.keys().hasOnly([
          "chatId",
          "participantIds",
          "participantPublicSummaries",
          "createdFromChatRequestId",
          "createdFromInterestRequestId",
          "status",
          "guardianApprovalStatus",
          "lastMessagePreview",
          "lastMessageAt",
          "createdAt",
          "updatedAt"
        ]);
      allow update: if isChatParticipant(chatId) &&
        request.resource.data.participantIds == resource.data.participantIds &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.createdFromChatRequestId == resource.data.createdFromChatRequestId &&
        changedOnly(["lastMessagePreview", "lastMessageAt", "updatedAt"]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId) || isAdmin();
        allow create: if isChatParticipant(chatId) &&
          chatData(chatId).status == "active" &&
          request.resource.data.keys().hasOnly([
            "messageId",
            "chatId",
            "senderId",
            "text",
            "type",
            "status",
            "createdAt",
            "updatedAt",
            "editedAt",
            "deletedAt"
          ]) &&
          request.resource.data.messageId == messageId &&
          request.resource.data.chatId == chatId &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 1000 &&
          request.resource.data.type == "text" &&
          request.resource.data.status == "sent";
        allow update: if isChatParticipant(chatId) &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.chatId == resource.data.chatId &&
          changedOnly(["status", "updatedAt"]) &&
          request.resource.data.status == "sent";
        allow delete: if false;
      }
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated() &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly(["fromUid", "toUid", "isMutual", "timestamp"]) &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.toUid is string &&
        request.resource.data.toUid != request.auth.uid &&
        request.resource.data.isMutual == false &&
        likeId == request.auth.uid + "_" + request.resource.data.toUid;
      allow update: if false;
      allow delete: if isAuthenticated() && resource.data.fromUid == request.auth.uid;
    }

    match /blocks/{blockId} {
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly(["blockerId", "blockedId", "timestamp"]) &&
        request.resource.data.blockerId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.blockerId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      function isMember(data) {
        return isAuthenticated() && request.auth.uid in data.memberIds;
      }

      function isWaliForRoom(data) {
        return isAuthenticated() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in data.memberIds;
      }

      function isWaliByEmail(data) {
        return isAuthenticated() &&
          request.auth.token.email != null &&
          data.get("waliEmail", null) != null &&
          request.auth.token.email == data.get("waliEmail", null);
      }

      allow read: if isMember(resource.data) || isWaliForRoom(resource.data) || isWaliByEmail(resource.data) || isAdmin();
      // Legacy chatRooms are read-only for clients. New client-created chats must
      // go through /chatRequests + /chats, or a privileged Cloud Function.
      allow create: if false;
      allow update: if isAdmin() ||
        (
          isMember(resource.data) &&
          changedOnly(["lastMessage", "lastMessageTimestamp", "dailyPrayers", "prayerStreaks"]) &&
          request.resource.data.memberIds == resource.data.memberIds &&
          request.resource.data.get("isChaperoned", false) == resource.data.get("isChaperoned", false) &&
          request.resource.data.get("waliEmail", null) == resource.data.get("waliEmail", null)
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function parentRoomData() {
          return get(/databases/$(database)/documents/chatRooms/$(roomId)).data;
        }

        allow read: if isAuthenticated() && (
          request.auth.uid in parentRoomData().memberIds ||
          (request.auth.token.email != null && parentRoomData().get("waliEmail", null) != null && request.auth.token.email == parentRoomData().get("waliEmail", null)) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in parentRoomData().memberIds) ||
          isAdmin()
        );
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasOnly(["senderId", "content", "timestamp", "translation"]) &&
          request.auth.uid in parentRoomData().memberIds &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 2000;
        allow update, delete: if isAdmin();
      }

      match /waliLogs/{logId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in
             get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds)
        );
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.isChaperoned == true;
        allow update, delete: if isAdmin();
      }
    }

    match /notifications/{notificationId} {
      // Notifications are server-created only. This prevents client spoofing and
      // keeps sensitive message/interest metadata out of user-controlled writes.
      allow create: if false;
      allow read, delete: if isAuthenticated() && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid &&
        changedOnly(["status"]) &&
        request.resource.data.status in ["DELIVERED", "READ"];
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /profile_views/{viewId} {
      allow create: if isAuthenticated() &&
        request.resource.data.viewerUid == request.auth.uid;
      allow read: if isAuthenticated() &&
        (resource.data.viewerUid == request.auth.uid || resource.data.viewedUid == request.auth.uid);
    }

    match /favorites/{favoriteId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userUid == request.auth.uid &&
        favoriteId == request.auth.uid + "_" + request.resource.data.favoriteUserUid;
      allow read: if isAuthenticated() &&
        (resource.data.userUid == request.auth.uid || resource.data.favoriteUserUid == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
