rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "isAdmin",
        "isPremium",
        "subscriptionPlan",
        "premiumExpiry",
        "verificationStatus",
        "guardianName",
        "guardianEmail",
        "guardianStatus",
        "photoAccessApprovedUsers",
        "photoAccessRequests",
        "isWaliAccount",
        "wardUid"
      ]);
    }

    function validInitialGuardianState() {
      return !("guardianStatus" in request.resource.data) ||
        request.resource.data.guardianStatus == "NONE" ||
        (
          request.resource.data.guardianStatus == "PENDING" &&
          request.resource.data.guardianName is string &&
          request.resource.data.guardianName.size() > 0 &&
          request.resource.data.guardianEmail is string &&
          request.resource.data.guardianEmail.size() > 3
        );
    }

    function validGuardianInvite() {
      return changedOnly(["guardianName", "guardianEmail", "guardianStatus"]) &&
        request.resource.data.guardianName is string &&
        request.resource.data.guardianName.size() > 0 &&
        request.resource.data.guardianEmail is string &&
        request.resource.data.guardianEmail.size() > 3 &&
        request.resource.data.guardianStatus == "PENDING";
    }

    function validWaliClaim() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        changedOnly(["isWaliAccount", "wardUid"]) &&
        request.resource.data.isWaliAccount == true &&
        request.resource.data.wardUid is string &&
        exists(/databases/$(database)/documents/users/$(request.resource.data.wardUid)) &&
        get(/databases/$(database)/documents/users/$(request.resource.data.wardUid)).data.guardianEmail == request.auth.token.email;
    }

    function validGuardianConfirmation() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        changedOnly(["guardianStatus"]) &&
        request.resource.data.guardianStatus == "VERIFIED" &&
        resource.data.guardianEmail == request.auth.token.email;
    }

    function validVerificationSubmission() {
      return isAuthenticated() &&
        changedOnly(["verificationStatus"]) &&
        request.resource.data.verificationStatus == "PENDING" &&
        resource.data.verificationStatus != "VERIFIED";
    }

    function existingPhotoRequests() {
      return ("photoAccessRequests" in resource.data)
        ? resource.data.photoAccessRequests
        : [];
    }

    function existingPhotoApprovedUsers() {
      return ("photoAccessApprovedUsers" in resource.data)
        ? resource.data.photoAccessApprovedUsers
        : [];
    }

    function validPhotoAccessRequest(userId) {
      return isAuthenticated() &&
        request.auth.uid != userId &&
        changedOnly(["photoAccessRequests"]) &&
        request.resource.data.photoAccessRequests is list &&
        request.resource.data.photoAccessRequests.hasAll(existingPhotoRequests()) &&
        request.auth.uid in request.resource.data.photoAccessRequests &&
        request.resource.data.photoAccessRequests.size() <= existingPhotoRequests().size() + 1;
    }

    function isAssignedWaliForUser(userId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid == userId;
    }

    function validPhotoAccessDecision() {
      return changedOnly(["photoAccessApprovedUsers", "photoAccessRequests"]) &&
        request.resource.data.photoAccessApprovedUsers is list &&
        request.resource.data.photoAccessRequests is list &&
        request.resource.data.photoAccessRequests.size() <= existingPhotoRequests().size() &&
        request.resource.data.photoAccessApprovedUsers.size() <= existingPhotoApprovedUsers().size() + 1;
    }

    function hasMutualMatch(memberIds) {
      return memberIds is list &&
        memberIds.size() == 2 &&
        (memberIds[0] is string) &&
        (memberIds[1] is string) &&
        (
          (
            exists(/databases/$(database)/documents/likes/$(memberIds[0] + "_" + memberIds[1])) &&
            get(/databases/$(database)/documents/likes/$(memberIds[0] + "_" + memberIds[1])).data.isMutual == true
          ) ||
          (
            exists(/databases/$(database)/documents/likes/$(memberIds[1] + "_" + memberIds[0])) &&
            get(/databases/$(database)/documents/likes/$(memberIds[1] + "_" + memberIds[0])).data.isMutual == true
          )
        );
    }

    function roomExistsFor(uidA, uidB) {
      return exists(/databases/$(database)/documents/chatRooms/$(uidA + "_" + uidB)) ||
        exists(/databases/$(database)/documents/chatRooms/$(uidB + "_" + uidA));
    }

    function relatedForNotification(recipientUid) {
      return recipientUid is string &&
        recipientUid.size() > 0 &&
        (
          recipientUid == request.auth.uid ||
          exists(/databases/$(database)/documents/likes/$(request.auth.uid + "_" + recipientUid)) ||
          exists(/databases/$(database)/documents/likes/$(recipientUid + "_" + request.auth.uid)) ||
          roomExistsFor(request.auth.uid, recipientUid)
        );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isOwner(userId) &&
        request.resource.data.uid == request.auth.uid &&
        !("isAdmin" in request.resource.data) &&
        request.resource.data.get("isPremium", false) == false &&
        request.resource.data.get("subscriptionPlan", "FREE") == "FREE" &&
        request.resource.data.get("premiumExpiry", 0) == 0 &&
        request.resource.data.get("isWaliAccount", false) == false &&
        !("wardUid" in request.resource.data) &&
        request.resource.data.get("verificationStatus", "NONE") == "NONE" &&
        validInitialGuardianState();

      allow update: if
        (isOwner(userId) && noPrivilegeEscalation()) ||
        (isOwner(userId) && validGuardianInvite()) ||
        (isOwner(userId) && validWaliClaim()) ||
        (isOwner(userId) && validVerificationSubmission()) ||
        (isOwner(userId) && validPhotoAccessDecision()) ||
        (isAssignedWaliForUser(userId) && validPhotoAccessDecision()) ||
        validGuardianConfirmation() ||
        validPhotoAccessRequest(userId);

      allow delete: if false;

      match /chatLimits/{limitId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly(["fromUid", "toUid", "isMutual", "timestamp"]) &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.toUid is string &&
        likeId == request.auth.uid + "_" + request.resource.data.toUid;
      allow update: if isAuthenticated() &&
        changedOnly(["isMutual"]) &&
        request.resource.data.isMutual == true &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.fromUid == request.auth.uid;
    }

    match /blocks/{blockId} {
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly(["blockerId", "blockedId", "timestamp"]) &&
        request.resource.data.blockerId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.blockerId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      function isMember(data) {
        return isAuthenticated() && request.auth.uid in data.memberIds;
      }

      function isWaliForRoom(data) {
        return isAuthenticated() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in data.memberIds;
      }

      function isWaliByEmail(data) {
        return isAuthenticated() &&
          request.auth.token.email != null &&
          data.get("waliEmail", null) != null &&
          request.auth.token.email == data.get("waliEmail", null);
      }

      allow read: if isMember(resource.data) || isWaliForRoom(resource.data) || isWaliByEmail(resource.data) || isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasOnly(["memberIds", "isChaperoned", "waliEmail", "lastMessage", "lastMessageTimestamp"]) &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.lastMessage is string &&
        request.resource.data.lastMessage.size() <= 2000 &&
        request.resource.data.lastMessageTimestamp is number &&
        (request.resource.data.waliEmail == null || (request.resource.data.waliEmail is string)) &&
        hasMutualMatch(request.resource.data.memberIds);
      allow update: if isAdmin() ||
        (
          isMember(resource.data) &&
          changedOnly(["lastMessage", "lastMessageTimestamp", "dailyPrayers", "prayerStreaks"]) &&
          request.resource.data.memberIds == resource.data.memberIds &&
          request.resource.data.get("isChaperoned", false) == resource.data.get("isChaperoned", false) &&
          request.resource.data.get("waliEmail", null) == resource.data.get("waliEmail", null)
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function parentRoomData() {
          return get(/databases/$(database)/documents/chatRooms/$(roomId)).data;
        }

        allow read: if isAuthenticated() && (
          request.auth.uid in parentRoomData().memberIds ||
          (request.auth.token.email != null && parentRoomData().get("waliEmail", null) != null && request.auth.token.email == parentRoomData().get("waliEmail", null)) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in parentRoomData().memberIds) ||
          isAdmin()
        );
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasOnly(["senderId", "content", "timestamp", "translation"]) &&
          request.auth.uid in parentRoomData().memberIds &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 2000;
        allow update, delete: if isAdmin();
      }

      match /waliLogs/{logId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in
             get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds)
        );
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.isChaperoned == true;
        allow update, delete: if isAdmin();
      }
    }

    match /notifications/{notificationId} {
      allow create: if false;
      allow read, delete: if isAuthenticated() && (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid &&
        changedOnly(["status"]) &&
        request.resource.data.status in ["DELIVERED", "READ"];
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /profile_views/{viewId} {
      allow create: if isAuthenticated() &&
        request.resource.data.viewerUid == request.auth.uid;
      allow read: if isAuthenticated() &&
        (resource.data.viewerUid == request.auth.uid || resource.data.viewedUid == request.auth.uid);
    }

    match /favorites/{favoriteId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userUid == request.auth.uid &&
        favoriteId == request.auth.uid + "_" + request.resource.data.favoriteUserUid;
      allow read: if isAuthenticated() &&
        (resource.data.userUid == request.auth.uid || resource.data.favoriteUserUid == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
