rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    // User is signed in via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // User is writing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Server-side admin check: reads the isAdmin field from Firestore itself,
    // so client-side tampering cannot grant admin access.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Fields a user is NOT allowed to self-modify (admin-only fields)
    function noPrivilegeEscalation() {
      return !("isAdmin" in request.resource.data.diff(resource.data).affectedKeys()) &&
             !("isPremium" in request.resource.data.diff(resource.data).affectedKeys()) &&
             !("subscriptionPlan" in request.resource.data.diff(resource.data).affectedKeys()) &&
             !("verificationStatus" in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── User Profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (needed for matchmaking)
      allow read: if isAuthenticated();

      // Creating your own profile: allowed, but you may not set admin/premium fields on create
      allow create: if isOwner(userId) &&
                       !("isAdmin" in request.resource.data) &&
                       request.resource.data.get("isPremium", false) == false &&
                       request.resource.data.get("verificationStatus", "NONE") == "NONE";

      // A user can update their own profile BUT cannot escalate their own privileges.
      // Admins can update any field on any profile (for verification, premium, etc.)
      allow update: if (isOwner(userId) && noPrivilegeEscalation()) || isAdmin();

      allow delete: if isAdmin();

      // Subcollection for daily chat limits
      match /chatLimits/{limitId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Likes / Matches ───────────────────────────────────────────────────────
    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.fromUid == request.auth.uid;
    }

    // ── Block List ────────────────────────────────────────────────────────────
    match /blocks/{blockId} {
      // Only the blocker can create/read/delete their own block entries
      allow read, create: if isAuthenticated() && resource == null
                                ? request.resource.data.blockerId == request.auth.uid
                                : resource.data.blockerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.blockerId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      // Only admins can read or delete reports
      allow read, delete: if isAdmin();
    }

    // ── Chat Rooms ────────────────────────────────────────────────────────────
    match /chatRooms/{roomId} {
      function isMember() {
        return isAuthenticated() && request.auth.uid in resource.data.memberIds;
      }
      function isWali() {
        return isAuthenticated() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in resource.data.memberIds;
      }
      function isWaliByEmail() {
        return isAuthenticated() &&
          resource.data.waliEmail != null &&
          request.auth.token.email == resource.data.waliEmail;
      }

      allow read: if isMember() || isWali() || isWaliByEmail() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.memberIds;
      allow update: if isMember() || isAdmin();
      allow delete: if isAdmin();

      // Chat Messages subcollection
      match /messages/{messageId} {
        function parentRoomData() {
          return get(/databases/$(database)/documents/chatRooms/$(roomId)).data;
        }
        allow read: if isAuthenticated() && (
          request.auth.uid in parentRoomData().memberIds ||
          (parentRoomData().waliEmail != null && request.auth.token.email == parentRoomData().waliEmail) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in parentRoomData().memberIds) ||
          isAdmin()
        );
        allow create: if isAuthenticated() &&
          request.auth.uid in parentRoomData().memberIds &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      // Wali monitoring logs: only walis and admins may read
      match /waliLogs/{logId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isWaliAccount == true &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.wardUid in
             get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds)
        );
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberIds;
        allow update, delete: if isAdmin();
      }
    }

    // ── FCM Tokens / Notifications ────────────────────────────────────────────
    // Handled via the users/{userId}.fcmToken field — covered by the users rule above.

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
    }

    // ── Profile Views ─────────────────────────────────────────────────────────
    match /profile_views/{viewId} {
      allow create: if isAuthenticated() && request.resource.data.viewerUid == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.viewerUid == request.auth.uid || resource.data.viewedUid == request.auth.uid);
    }

    // ── Favorites ─────────────────────────────────────────────────────────────
    match /favorites/{favoriteId} {
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow read: if isAuthenticated() && (resource == null || resource.data.userUid == request.auth.uid || resource.data.favoriteUserUid == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userUid == request.auth.uid;
    }

    // ── Deny all other reads/writes ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
